# For finding min spanning tree we can use greedy approach like for each node select only those edge which has min         weight and it should also be relevent.

# The basic ideo of this algorithm is to use Min Heap to extract the Minimum weighted edge process for its next optimal    neighbour.

  TC -> O(E logE)
  SC -> O(E + V)

# Code->

        priority_queue<pair<int, int>, vector<pair<int, int>>,greater<pair<int, int>>> pq;
        vector<bool> visited(V , false);

        int sum = 0;
        pq.push({0, 0});

        while (!pq.empty()) {
            auto P = pq.top();
            pq.pop();

            int wt = P.first;
            int node = P.second;

            if(visited[node] == true) continue;

            visited[node] = true;
            sum += wt;

            for(auto vec : adj[node]){
                int next_node = vec[0];
                int next_wt = vec[1];

                if(visited[next_node] == false){
                    pq.push({next_wt , next_node});
                }
            }
        }

        return sum;

